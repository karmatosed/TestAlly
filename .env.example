# ── Per-Role LLM Configuration ──
# Each role can have its own provider, key, host, and model.
# Provider options: anthropic, openai, deepseek, cloudfest
# Falls back to cloudfest if not set.

# Planning Agent (decides which analysis tools to run)
PLANNING_LLM_PROVIDER=deepseek
PLANNING_LLM_PROVIDER_KEY=sk-xxxxxxxxxxxxx
PLANNING_LLM_PROVIDER_HOST=https://api.deepseek.com
PLANNING_LLM_PROVIDER_MODEL=deepseek-chat

# Walkthrough Generation (produces ITTT manual test steps)
GENERATION_LLM_PROVIDER=deepseek
GENERATION_LLM_PROVIDER_KEY=sk-xxxxxxxxxxxxx
GENERATION_LLM_PROVIDER_HOST=https://api.deepseek.com
GENERATION_LLM_PROVIDER_MODEL=deepseek-chat

# Walkthrough Validation (cross-checks accuracy, returns confidence score)
VALIDATION_LLM_PROVIDER=deepseek
VALIDATION_LLM_PROVIDER_KEY=sk-xxxxxxxxxxxxx
VALIDATION_LLM_PROVIDER_HOST=https://api.deepseek.com
VALIDATION_LLM_PROVIDER_MODEL=deepseek-chat

# Inference (lightweight paste classification at /api/infer-component, Chat tab, /api/health/llm)
# Uses raw fetch, not LangChain. Defaults to cloudfest if not set.
# INFERENCE_LLM_PROVIDER=cloudfest
# INFERENCE_LLM_PROVIDER_KEY=
# INFERENCE_LLM_PROVIDER_HOST=
# INFERENCE_LLM_PROVIDER_MODEL=llama3.1:70b

# Inference tuning
# LLM_INFER_TIMEOUT_MS=120000

# ── Optional: single OpenAI-compatible URL (Ollama, local gateway) ──
# If set, it overrides the inference *base URL* for raw-fetch routes (infer, chat, health/llm).
# Ollama: http://localhost:11434 OR http://localhost:11434/v1 — avoid duplicating /v1 in paths.
# LLM_API_URL=http://localhost:11434
# LLM_TOKEN=
# LLM_MODEL=llama3:8b
# LLM_CHAT_PATH=v1/chat/completions
# LLM_CHAT_TIMEOUT_MS=120000
# Client-side max wait for POST /api/chat-component (ms); should be ≥ server LLM_CHAT_TIMEOUT_MS
# VITE_CHAT_TIMEOUT_MS=135000
# Ollama: JSON-shaped completions for Chat (ignored by many other servers)
# LLM_JSON_FORMAT=json

# Timeout (ms) for GET /api/health/llm probes (Ollama tags / v1/models)
# LLM_PROBE_TIMEOUT_MS=8000

# ── Application Settings ──
APP_URL=http://localhost:5173
API_PORT=3001
# If the server log shows "Port … is already in use (EADDRINUSE)", the TestAlly API never starts.
# Vite still proxies /api to API_PORT, so Chat/infer hit whatever else is on that port (often broken).
# Fix: free the port (`lsof -i :3001`) or set API_PORT to a free port here and restart `npm run dev`.
# When 5173 is taken: DEV_CLIENT_PORT=5180
NODE_ENV=development

# ── Rate Limiting ──
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_ANALYZE_MAX=20
RATE_LIMIT_ANALYZE_WINDOW_MS=60000
RATE_LIMIT_READ_MAX=60
RATE_LIMIT_READ_WINDOW_MS=60000

# ── Analysis Settings ──
MAX_INPUT_SIZE_KB=50
ANALYSIS_TIMEOUT_MS=30000

# ── LangSmith Tracing (optional — set to 'true' to enable) ──
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=lsv2_pt_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LANGSMITH_PROJECT=testally-dev
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
