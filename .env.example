# LLM Provider API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxx

# OpenAI-compatible HTTP API (host:port or full URL; scheme optional).
# Ollama: use http://localhost:11434 OR http://localhost:11434/v1 — not both duplicated in paths.
LLM_API_URL=http://localhost:11434
# Optional bearer token for the LLM gateway
LLM_TOKEN=
# Model id for /v1/chat/completions — must match `ollama list` (e.g. llama3:8b, qwen3:8b)
LLM_MODEL=llama3:8b
# Override chat path if your gateway differs (default v1/chat/completions)
# LLM_CHAT_PATH=v1/chat/completions
# LLM_INFER_TIMEOUT_MS=120000
# LLM_CHAT_TIMEOUT_MS=120000
# Client-side max wait for POST /api/chat-component (ms); should be ≥ server LLM_CHAT_TIMEOUT_MS
# VITE_CHAT_TIMEOUT_MS=135000
# Timeout (ms) for GET /api/health/llm probes (Ollama tags / v1/models)
# LLM_PROBE_TIMEOUT_MS=8000
# Ollama: ask the model for JSON-shaped output (reduces chat errors). Ignored by most OpenAI-compatible servers.
# LLM_JSON_FORMAT=json

# Application Settings
APP_URL=http://localhost:5173
API_PORT=3001
# If the server log shows "Port … is already in use (EADDRINUSE)", the TestAlly API never starts.
# Vite still proxies /api to API_PORT, so Chat/infer hit whatever else is on that port (often broken).
# Fix: free the port (`lsof -i :3001`) or set API_PORT to a free port here and restart `npm run dev`.
# When 5173 is taken: DEV_CLIENT_PORT=5180
NODE_ENV=development

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_ANALYZE_MAX=20
RATE_LIMIT_ANALYZE_WINDOW_MS=60000
RATE_LIMIT_READ_MAX=60
RATE_LIMIT_READ_WINDOW_MS=60000

# Analysis Settings
MAX_INPUT_SIZE_KB=50
ANALYSIS_TIMEOUT_MS=30000
